# ==============================================================================
# AI Template Studio - Backend Environment Variables
# ==============================================================================

# -------------------------
# Application Configuration
# -------------------------
NODE_ENV=development
PORT=4000

# -------------------------
# Database & Redis
# -------------------------
# Prisma requires a valid connection string.
DATABASE_URL=postgresql://studio:studio@postgres:5432/aistudio

# If you use docker-compose, REDIS_HOST=redis is fine.
# If running locally without docker network, use localhost.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# REDIS_URL=redis://user:password@host:port (Use this if providing a full connection string, overrides HOST/PORT)

# -------------------------
# Security & Auth Secrets (CRITICAL)
# -------------------------
# In production, these MUST be long, random, cryptographically secure strings.
# You can generate one via: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_at_least_64_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
REFRESH_SECRET=your_refresh_secret_at_least_64_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ENCRYPTION_KEY must be exactly 64 hex characters (32 bytes) for AES-256-GCM
ENCRYPTION_KEY=abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789

# -------------------------
# Frontend Configuration
# -------------------------
# Allowed origin for CORS (where your frontend is hosted)
FRONTEND_URL=http://localhost:3000
# Alternatively, FRONTEND_HOST=ai-studio-frontend-xxxx.onrender.com

# -------------------------
# Storage Configuration
# -------------------------
# STORAGE_MODE can be 's3' or 'local'.
# Local mode saves generated images to backend/uploads.
STORAGE_MODE=s3

# S3 / MinIO settings
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=ai-studio
STORAGE_PUBLIC_URL=http://localhost:9000/ai-studio

# -------------------------
# External APIs (Optional)
# -------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
