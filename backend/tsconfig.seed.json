{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist/prisma",
    "rootDir": "./prisma",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "sourceMap": false,
    "declaration": false
  },
  "include": ["prisma/seed.ts"],
  "exclude": ["node_modules"]
}
