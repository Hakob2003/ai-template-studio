# ==============================================================================
# AI Template Studio - Frontend Environment Variables
# ==============================================================================
# Note: Next.js uses .env.local for local development overriding.

# -------------------------
# Backend Connection
# -------------------------
# The URL where the frontend makes its API requests.
# In local development, it points to the local backend.
# In production, when using Next.js Rewrites, this can be empty as API calls go to relative /api paths.
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# The URL for WebSocket connections (Socket.io)
# Must point directly to the backend domain.
NEXT_PUBLIC_WS_URL=http://localhost:4000

# BACKEND_URL is used by Next.js rewrites in next.config.js to proxy /api requests securely.
# This prevents exposing your backend host directly on the client.
BACKEND_URL=http://localhost:4000
